#!/usr/bin/env -S python3 -u
"""
CAPA CLI - Declarative cluster lifecycle management

Usage:
    ./capa create -f specs/default.yml -e name_prefix=test1
    ./capa create --profile default -e name_prefix=test1
    ./capa upgrade --cluster moo-rosa-hcp --version 4.20.12
    ./capa apply -f specs/day2-test.yml --cluster moo-rosa-hcp
    ./capa set channel_group fast -c moo-rosa-hcp     # quick single-feature change
    ./capa delete --cluster moo-rosa-hcp
    ./capa status --cluster moo-rosa-hcp
    ./capa specs                    # list available specs/profiles
    ./capa features                 # list all features
    ./capa test 20-rosa-hcp-provision --ai-agent -VVV    # run test suite
    ./capa test --list                                  # list test suites
    ./capa validate specs/features/channel-group.yml   # validate a spec file
    ./capa plan -f specs/upgrade.yml --cluster moo --version 4.20.12  # dry run
    ./capa version                                      # show CLI/agent versions
    ./capa list-clusters                                # list all managed clusters
    ./capa logs --cluster moo-rosa-hcp                  # tail sidecar/job logs
    ./capa history --cluster moo-rosa-hcp               # show operation history
    ./capa watch --cluster moo-rosa-hcp                 # poll status until ready
    ./capa completion bash                              # generate shell completion
    ./capa workflow list                                  # list all workflows
    ./capa workflow show verify_and_configure             # show workflow details
    ./capa workflow run verify_and_configure              # run a workflow
    ./capa workflow run verify_and_configure -e key=val   # run with overrides
    ./capa workflow export verify_and_configure           # export saved workflow to YAML
"""

import argparse
