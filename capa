def cmd_generate_specs(args, base_dir, registry):
    """Auto-generate feature spec files from the registry."""
    features_dir = base_dir / "specs" / "features"
    features_dir.mkdir(parents=True, exist_ok=True)

    generated = 0
    skipped = 0
    for feat_id, feat in registry.all_features().items():
        applies_to = feat.get("applies_to", [])
        # Only generate specs for features that can be applied to running clusters
        if "apply" not in applies_to and "upgrade" not in applies_to and "delete" not in applies_to:
            continue

        filename = feat_id.replace("_", "-") + ".yml"
        filepath = features_dir / filename

        if filepath.exists() and not args.force:
            skipped += 1
            continue

        # Determine action type
        if feat.get("destructive"):
            action = "delete"
        else:
            action = "apply"

        # Build default value based on type
        default_value = feat.get("default", "")
        if feat["type"] == "boolean":
            default_value = True
        elif feat["type"] == "select":
            opts = feat.get("options", [])
            default_value = opts[0] if opts else ""
        elif feat["type"] == "key_value":
            default_value = None  # user must provide
        elif feat["type"] == "range":
            default_value = feat.get("default", {"min": 2, "max": 4})
        elif feat["type"] == "version":
            default_value = ""  # user must provide via -e version=

        spec = {
            "apiVersion": "capa-automation/v1",
            "kind": "ClusterAutomationSpec",
            "metadata": {"name": feat_id.replace("_", "-")},
            "spec": {
                "action": action,
                "cluster": "",
                "namespace": "ns-rosa-hcp",
            },
        }

        if action == "delete":
            # Delete specs don't need actions list
            pass
        else:
            action_entry = {"feature": feat_id}
            if default_value is not None and default_value != "":
                action_entry["value"] = default_value
            if feat.get("wait_timeout"):
                action_entry["wait"] = True
            spec["spec"]["actions"] = [action_entry]

        # Write with comments
        with open(filepath, "w") as f:
            f.write(f"# Auto-generated from feature-registry.yml\n")
            f.write(f"# Feature: {feat.get('name', feat_id)}\n")
            f.write(f"# Applies to: {', '.join(applies_to)}\n")
            yaml.dump(spec, f, default_flow_style=False, sort_keys=False)

        generated += 1
        print(f"  {C.G}+{C.E} {filename}")

    print(f"\n{C.BOLD}Generated: {generated} specs, skipped: {skipped} (already exist){C.E}")
    if skipped > 0:
        print(f"  Use --force to overwrite existing specs")
    print()


def _evaluate_condition(condition, results):
    """Evaluate a step condition against previous results.

    Supported conditions:
      - None / empty        -> True (always run if no prior failures, handled by caller)
      - "always"            -> True (run regardless)
      - "failure"           -> True if any previous step failed
      - "success"           -> True if all previous steps completed
      - "steps.N.status == 'completed'"  -> check specific step status
      - "steps.N.status != 'failed'"     -> negative check
    """
    if not condition:
        return True
    cond = condition.strip()

    if cond == "always":
        return True
    if cond == "failure":
        return any(r.get("status") == "failed" for r in results)
    if cond == "success":
        return all(r.get("status") == "completed" for r in results)

    # Parse: steps.N.status == 'value' or steps.N.status != 'value'
    import re as _re
    m = _re.match(r"steps\.(\d+)\.status\s*(==|!=)\s*['\"](\w+)['\"]", cond)
    if m:
        step_num = int(m.group(1))
        op = m.group(2)
        expected = m.group(3)
        # Find result for step_num
        step_result = next((r for r in results if r.get("step") == step_num), None)
        if not step_result:
            return False  # Referenced step hasn't run yet
        actual = step_result.get("status", "")
        if op == "==":
            return actual == expected
        elif op == "!=":
            return actual != expected

    # Unknown condition — warn and skip
    print(f"  {C.Y}Unknown condition: {cond} — skipping step{C.E}")
    return False


def cmd_workflow(args, base_dir, registry):
    """List, show, or run saved workflows."""
    action = getattr(args, "workflow_action", None) or "list"
    workflows_file = base_dir / "vars" / "saved_workflows.json"

    def _load_saved():
        """Load workflows from vars/saved_workflows.json."""
        if not workflows_file.exists():
            return []
        try:
            with open(workflows_file) as f:
                return json.load(f)
        except (json.JSONDecodeError, IOError):
            return []

    def _load_yaml_workflows():
        """Load YAML workflow files from specs/workflows/."""
        wf_dir = base_dir / "specs" / "workflows"
        results = []
        if not wf_dir.exists():
            return results
        for yf in sorted(wf_dir.glob("*.yml")):
            try:
                with open(yf) as f:
                    data = yaml.safe_load(f)
                if data and data.get("kind") == "Workflow":
                    data["_source"] = str(yf)
                    results.append(data)
            except (yaml.YAMLError, IOError):
                continue
        return results

    def _find_workflow(name):
        """Find a workflow by name from saved JSON or YAML files."""
        # Check saved workflows first
        for wf in _load_saved():
            if wf.get("name") == name or wf.get("id") == name:
                return wf, "saved"
        # Check YAML workflows
        for wf in _load_yaml_workflows():
            meta = wf.get("metadata", {})
            if meta.get("name") == name:
                return wf, "yaml"
        # Check by filename stem
        yf = base_dir / "specs" / "workflows" / f"{name}.yml"
        if yf.exists():
            with open(yf) as f:
                data = yaml.safe_load(f)
            if data:
                data["_source"] = str(yf)
                return data, "yaml"
        return None, None

    def _workflow_to_plan(wf, wf_type, extra_vars_overrides=None):
        """Convert a workflow (saved JSON or YAML) to an execution plan."""
        steps = []

        # Extract global vars and steps from either format
        if wf_type == "yaml":
            global_vars = wf.get("spec", {}).get("vars", {})
            raw_steps = wf.get("spec", {}).get("steps", [])
        else:
            # Saved: support both old (globalVars/file/onFailure/extra_vars) and new (vars/playbook/on_failure/vars)
            global_vars = wf.get("vars", wf.get("globalVars", {}))
            raw_steps = wf.get("steps", [])

        for i, step in enumerate(raw_steps):
            step_vars = step.get("vars", step.get("extra_vars", {}))
            merged_vars = {**global_vars, **step_vars}
            if extra_vars_overrides:
                merged_vars.update(extra_vars_overrides)
            steps.append({
                "step": i + 1,
                "type": "playbook",
                "name": step.get("name", f"Step {i+1}"),
                "playbook": step.get("playbook", step.get("file", "")),
                "extra_vars": merged_vars,
                "on_failure": step.get("on_failure", step.get("onFailure", "stop")),
                "timeout": step.get("timeout", 600),
                "if": step.get("if"),
            })
        return steps

    if action == "list":
        saved = _load_saved()
        yaml_wfs = _load_yaml_workflows()

        if not saved and not yaml_wfs:
            print(f"{C.Y}No workflows found.{C.E}")
            print(f"  Save workflows in the UI Workflow Builder, or create YAML files in specs/workflows/")
            return

        if saved:
            print(f"\n{C.BOLD}Saved Workflows{C.E} ({workflows_file.name}):\n")
            for wf in saved:
                step_count = len(wf.get("steps", []))
                saved_at = wf.get("savedAt", "")[:16]
                print(f"  {C.G}{wf['name']}{C.E}  ({step_count} steps)  saved: {saved_at}")
                for i, step in enumerate(wf.get("steps", []), 1):
                    print(f"    {i}. {step.get('name', '?')}")

        if yaml_wfs:
            print(f"\n{C.BOLD}YAML Workflows{C.E} (specs/workflows/):\n")
            for wf in yaml_wfs:
                meta = wf.get("metadata", {})
                spec = wf.get("spec", {})
                step_count = len(spec.get("steps", []))
                print(f"  {C.B}{meta.get('name', '?')}{C.E}  ({step_count} steps)  {meta.get('description', '')}")
                for i, step in enumerate(spec.get("steps", []), 1):
                    print(f"    {i}. {step.get('name', '?')}")
        print()

    elif action == "show":
        name = getattr(args, "name", None)
        if not name:
            print(f"{C.R}Usage: capa workflow show <name>{C.E}")
            sys.exit(1)
        wf, wf_type = _find_workflow(name)
        if not wf:
            print(f"{C.R}Workflow not found: {name}{C.E}")
            sys.exit(1)

        if wf_type == "saved":
            wf_name = wf.get("name", name)
            print(f"\n{C.BOLD}Workflow: {wf_name}{C.E}")
            print(f"  ID: {wf.get('id', 'n/a')}")
            print(f"  Stop on failure: {wf.get('stop_on_failure', wf.get('stopOnFailure', True))}")
            gv = wf.get("vars", wf.get("globalVars", {}))
        elif wf_type == "yaml":
            wf_name = wf.get("metadata", {}).get("name", name)
            print(f"\n{C.BOLD}Workflow: {wf_name}{C.E}  ({wf.get('_source', '')})")
            print(f"  Description: {wf.get('metadata', {}).get('description', '')}")
            gv = wf.get("spec", {}).get("vars", {})

        if gv:
            print(f"\n  {C.BOLD}Variables:{C.E}")
            for k, v in gv.items():
                display_v = "***" if "secret" in k.lower() or "password" in k.lower() else v
                print(f"    {k} = {display_v}")

        # Steps — unified display for both formats
        raw_steps = wf.get("steps", []) if wf_type == "saved" else wf.get("spec", {}).get("steps", [])
        print(f"\n  {C.BOLD}Steps:{C.E}")
        for i, step in enumerate(raw_steps, 1):
            print(f"    {i}. {step.get('name', '?')}")
            print(f"       playbook: {step.get('playbook', step.get('file', '?'))}")
            print(f"       on_failure: {step.get('on_failure', step.get('onFailure', 'stop'))}")
            if step.get("if"):
                print(f"       {C.Y}if: {step['if']}{C.E}")
            sv = step.get("vars", step.get("extra_vars", {}))
            if sv:
                print(f"       vars: {json.dumps(sv, indent=2).replace(chr(10), chr(10) + '       ')}")
        print()

    elif action == "run":
        name = getattr(args, "name", None)
        if not name:
            print(f"{C.R}Usage: capa workflow run <name>{C.E}")
            sys.exit(1)
        wf, wf_type = _find_workflow(name)
        if not wf:
            print(f"{C.R}Workflow not found: {name}{C.E}")
            sys.exit(1)

        # Parse -e overrides
        extra_vars_overrides = {}
        raw_extras = getattr(args, "extra_vars", None) or []
        for item in raw_extras:
            if "=" in item:
                k, v = item.split("=", 1)
                extra_vars_overrides[k] = v

        plan = _workflow_to_plan(wf, wf_type, extra_vars_overrides)
        if not plan:
            print(f"{C.R}Workflow has no steps.{C.E}")
            sys.exit(1)

        dry_run = args.dry_run
        engine = ExecutionEngine(registry, base_dir, dry_run=dry_run, verbose=args.verbose)

        # Use the workflow's on_failure policy per step
        stop_on_failure = wf.get("stop_on_failure", wf.get("stopOnFailure", True)) if wf_type == "saved" else True

        print(f"\n{C.BOLD}{C.CYAN}{'=' * 60}{C.E}")
        wf_name = wf.get("name") or wf.get("metadata", {}).get("name", name)
        print(f"{C.BOLD}  Workflow: {wf_name} ({len(plan)} steps){C.E}")
        print(f"{C.BOLD}{C.CYAN}{'=' * 60}{C.E}\n")

        for step in plan:
            engine._print_step(step)

        if dry_run:
            print(f"\n{C.Y}DRY RUN — no changes made.{C.E}\n")
            return

        print(f"\n{C.BOLD}Executing...{C.E}\n")
        results = []
        workflow_failed = False
        for step in plan:
            # Evaluate conditional
            cond = step.get("if")
            if cond:
                should_run = _evaluate_condition(cond, results)
                if not should_run:
                    print(f"  {C.Y}○ Step {step['step']}: {step['name']} — skipped (condition: {cond}){C.E}")
                    results.append({"step": step["step"], "name": step["name"], "status": "skipped"})
                    continue
            elif workflow_failed:
                # No explicit condition, but a prior step failed — skip unless on_failure allows
                print(f"  {C.Y}○ Step {step['step']}: {step['name']} — skipped (prior failure){C.E}")
                results.append({"step": step["step"], "name": step["name"], "status": "skipped"})
                continue

            result = engine._execute_step(step)
            results.append(result)

            if result["status"] == "failed":
                on_failure = step.get("on_failure", "stop")
                if on_failure == "stop" or (on_failure != "skip" and stop_on_failure):
                    print(f"\n{C.R}Step {step['step']} failed — stopping workflow.{C.E}")
                    workflow_failed = True
                    # Only skip remaining steps that don't have an explicit condition
                    # Steps with conditions (like "always" or "failure") still get evaluated
                    continue
                elif on_failure == "skip":
                    print(f"  {C.Y}Step failed — skipping (on_failure: skip){C.E}")

        engine._print_summary(results)

    elif action == "export":
        name = getattr(args, "name", None)
        if not name:
            print(f"{C.R}Usage: capa workflow export <name>{C.E}")
            sys.exit(1)
        wf, wf_type = _find_workflow(name)
        if not wf:
            print(f"{C.R}Workflow not found: {name}{C.E}")
            sys.exit(1)

        if wf_type == "yaml":
            print(f"{C.Y}Already a YAML workflow: {wf.get('_source')}{C.E}")
            return

        # Convert saved JSON workflow to YAML format
        yaml_wf = {
            "apiVersion": "capa-automation/v1",
            "kind": "Workflow",
            "metadata": {
                "name": wf["name"],
                "description": wf.get("description", ""),
            },
            "spec": {
                "vars": wf.get("vars", wf.get("globalVars", {})),
                "steps": [],
            },
        }
        for step in wf.get("steps", []):
            yaml_step = {
                "name": step.get("name", ""),
                "playbook": step.get("playbook", step.get("file", "")),
                "on_failure": step.get("on_failure", step.get("onFailure", "stop")),
                "timeout": step.get("timeout", 600),
            }
            if step.get("if"):
                yaml_step["if"] = step["if"]
            sv = step.get("vars", step.get("extra_vars", {}))
            if sv:
                yaml_step["vars"] = sv
            yaml_wf["spec"]["steps"].append(yaml_step)

        out_path = base_dir / "specs" / "workflows" / f"{wf['name']}.yml"
        print(f"\n{C.BOLD}Exported YAML:{C.E}\n")
        yaml_str = yaml.dump(yaml_wf, default_flow_style=False, sort_keys=False)
        print(yaml_str)

        if getattr(args, "output", None):
            out_path = Path(args.output)

        print(f"{C.CYAN}Save to: {out_path}{C.E}")
        confirm = input("Write file? [y/N] ").strip().lower()
        if confirm == "y":
            out_path.parent.mkdir(parents=True, exist_ok=True)
            with open(out_path, "w") as f:
                f.write(f"# Exported from UI workflow: {wf['name']}\n")
                yaml.dump(yaml_wf, f, default_flow_style=False, sort_keys=False)
            print(f"{C.G}Written: {out_path}{C.E}")
    else:
        print(f"{C.R}Unknown workflow action: {action}{C.E}")
        print(f"Usage: capa workflow [list|show|run|export] <name>")
        sys.exit(1)


def _load_trigger_state(base_dir):
    """Load trigger state from vars/trigger_state.json (file-locked)."""
    import fcntl
    state_file = base_dir / "vars" / "trigger_state.json"
    if not state_file.exists():
        return {"triggers": [], "run_history": []}
    try:
        with open(state_file) as f:
            fcntl.flock(f, fcntl.LOCK_SH)
            try:
                return json.load(f)
            finally:
                fcntl.flock(f, fcntl.LOCK_UN)
    except (json.JSONDecodeError, IOError):
        return {"triggers": [], "run_history": []}


def _save_trigger_state(base_dir, state):
    """Persist trigger state to vars/trigger_state.json (file-locked)."""
    import fcntl
    state_file = base_dir / "vars" / "trigger_state.json"
    state_file.parent.mkdir(parents=True, exist_ok=True)
    # Cap run history at 200 entries
    if len(state.get("run_history", [])) > 200:
        state["run_history"] = state["run_history"][-200:]
    with open(state_file, "w") as f:
        fcntl.flock(f, fcntl.LOCK_EX)
        try:
            json.dump(state, f, indent=2, default=str)
        finally:
            fcntl.flock(f, fcntl.LOCK_UN)


def _generate_trigger_id():
    """Generate a short unique trigger ID."""
    import hashlib
    return "trg-" + hashlib.sha256(os.urandom(16)).hexdigest()[:16]


def _next_cron_time(cron_expr, tz_name="UTC"):
    """Calculate next run time from a cron expression. Returns ISO string or None."""
    try:
        from croniter import croniter
        from datetime import datetime, timezone
        now = datetime.now(timezone.utc)
        cron = croniter(cron_expr, now)
        next_dt = cron.get_next(datetime)
        return next_dt.isoformat()
    except ImportError:
        # croniter not installed — return estimate
        return None
    except (ValueError, KeyError):
        return None


def _cron_to_human(cron_expr):
    """Convert a cron expression to a human-readable description."""
    parts = cron_expr.strip().split()
    if len(parts) != 5:
        return cron_expr
    minute, hour, dom, month, dow = parts
    # Common patterns
    if minute != "*" and hour != "*" and dom == "*" and month == "*" and dow == "*":
        return f"Daily at {hour}:{minute.zfill(2)}"
    if minute != "*" and hour != "*" and dom == "*" and month == "*" and dow != "*":
        days = {"0": "Sun", "1": "Mon", "2": "Tue", "3": "Wed", "4": "Thu", "5": "Fri", "6": "Sat"}
        day = days.get(dow, dow)
        return f"Every {day} at {hour}:{minute.zfill(2)}"
    if minute != "*" and hour == "*":
        return f"Every hour at :{minute.zfill(2)}"
    if minute == "*" and hour == "*":
        return "Every minute"
    return cron_expr


def _find_workflow_for_trigger(name, base_dir):
    """Find a workflow by name (for trigger create). Returns (wf, wf_type) or (None, None)."""
    # Check saved workflows
    wf_json = base_dir / "vars" / "saved_workflows.json"
    if wf_json.exists():
        try:
            with open(wf_json) as f:
                for wf in json.load(f):
                    if wf.get("name") == name:
                        return wf, "saved"
        except (json.JSONDecodeError, IOError):
            pass
    # Check YAML workflows
    wf_dir = base_dir / "specs" / "workflows"
    if wf_dir.exists():
        for yf in sorted(wf_dir.glob("*.yml")):
            try:
                with open(yf) as f:
                    data = yaml.safe_load(f)
                if data and data.get("kind") == "Workflow":
                    wf_name = data.get("metadata", {}).get("name", yf.stem)
                    if wf_name == name:
                        data["_source"] = str(yf)
                        return data, "yaml"
            except (yaml.YAMLError, IOError):
                pass
    return None, None


def _run_workflow_by_name(workflow_name, base_dir, registry, vars_override=None, verbose=False):
    """Execute a workflow by name. Returns (success, results, elapsed)."""
    import time as _time
    wf, wf_type = _find_workflow_for_trigger(workflow_name, base_dir)
    if not wf:
        print(f"{C.R}Workflow not found: {workflow_name}{C.E}")
        return False, [], 0

    # Import _workflow_to_plan from cmd_workflow scope — we need to inline it here
    # since it's a nested function. Reconstruct the plan directly.
    steps = []
    if wf_type == "yaml":
        global_vars = wf.get("spec", {}).get("vars", {})
        raw_steps = wf.get("spec", {}).get("steps", [])
    else:
        global_vars = wf.get("vars", wf.get("globalVars", {}))
        raw_steps = wf.get("steps", [])

    for i, step in enumerate(raw_steps):
        step_vars = step.get("vars", step.get("extra_vars", {}))
        merged_vars = {**global_vars, **step_vars}
        if vars_override:
            merged_vars.update(vars_override)
        steps.append({
            "step": i + 1,
            "type": "playbook",
            "name": step.get("name", f"Step {i+1}"),
            "playbook": step.get("playbook", step.get("file", "")),
            "extra_vars": merged_vars,
            "on_failure": step.get("on_failure", step.get("onFailure", "stop")),
            "timeout": step.get("timeout", 600),
            "if": step.get("if"),
        })

    if not steps:
        print(f"{C.R}Workflow has no steps.{C.E}")
        return False, [], 0

    engine = ExecutionEngine(registry, base_dir, dry_run=False, verbose=verbose)
    stop_on_failure = wf.get("stop_on_failure", wf.get("stopOnFailure", True)) if wf_type == "saved" else True
    wf_name = wf.get("name") or wf.get("metadata", {}).get("name", workflow_name)

    print(f"\n{C.BOLD}{C.CYAN}{'=' * 60}{C.E}")
    print(f"{C.BOLD}  Workflow: {wf_name} ({len(steps)} steps){C.E}")
    print(f"{C.BOLD}{C.CYAN}{'=' * 60}{C.E}\n")

    start = _time.time()
    results = []
    workflow_failed = False
    for step in steps:
        cond = step.get("if")
        if cond:
            should_run = _evaluate_condition(cond, results)
            if not should_run:
                print(f"  {C.Y}○ Step {step['step']}: {step['name']} — skipped (condition: {cond}){C.E}")
                results.append({"step": step["step"], "name": step["name"], "status": "skipped"})
                continue
        elif workflow_failed:
            print(f"  {C.Y}○ Step {step['step']}: {step['name']} — skipped (prior failure){C.E}")
            results.append({"step": step["step"], "name": step["name"], "status": "skipped"})
            continue

        result = engine._execute_step(step)
        results.append(result)

        if result["status"] == "failed":
            on_failure = step.get("on_failure", "stop")
            if on_failure == "stop" or (on_failure != "skip" and stop_on_failure):
                print(f"\n{C.R}Step {step['step']} failed — stopping workflow.{C.E}")
                workflow_failed = True
                continue
            elif on_failure == "skip":
                print(f"  {C.Y}Step failed — skipping (on_failure: skip){C.E}")

    elapsed = _time.time() - start
    engine._print_summary(results)
    success = all(r["status"] in ("completed", "skipped") for r in results)
    return success, results, elapsed


def cmd_trigger(args, base_dir, registry):
    """Manage workflow triggers (schedule and webhook)."""
    action = getattr(args, "trigger_action", None) or "list"
    state = _load_trigger_state(base_dir)
    triggers = state.get("triggers", [])

    if action == "list":
        # Also scan YAML workflows for declared triggers
        yaml_triggers = []
        wf_dir = base_dir / "specs" / "workflows"
        if wf_dir.exists():
            for yf in sorted(wf_dir.glob("*.yml")):
                try:
                    with open(yf) as f:
                        data = yaml.safe_load(f)
                    if data and data.get("kind") == "Workflow":
                        wf_name = data.get("metadata", {}).get("name", yf.stem)
                        for t in data.get("spec", {}).get("triggers", []):
                            t["_workflow"] = wf_name
                            t["_source"] = str(yf)
                            yaml_triggers.append(t)
                except (yaml.YAMLError, IOError):
                    pass

        if not triggers and not yaml_triggers:
            print(f"{C.Y}No triggers configured.{C.E}")
            print(f"  Create one with: capa trigger create <workflow> --type schedule --cron '0 2 * * *'")
            return

        if triggers:
            print(f"\n{C.BOLD}Active Triggers{C.E} (vars/trigger_state.json):\n")
            for t in triggers:
                status_icon = f"{C.G}●{C.E}" if t.get("enabled", True) else f"{C.Y}○{C.E}"
                ttype = t.get("type", "?")
                wf = t.get("workflow_name", "?")
                tid = t.get("trigger_id", "?")
                if ttype == "schedule":
                    cron = t.get("cron", "?")
                    human = _cron_to_human(cron)
                    next_run = t.get("next_run_at", "")
                    next_str = f"  next: {next_run[:16]}" if next_run else ""
                    print(f"  {status_icon} {C.B}{tid}{C.E}  {ttype}  {C.G}{wf}{C.E}  {human} ({cron}){next_str}")
                elif ttype == "webhook":
                    print(f"  {status_icon} {C.B}{tid}{C.E}  {ttype}  {C.G}{wf}{C.E}  POST /api/webhooks/trigger/{tid}")
                last = t.get("last_run_at")
                if last:
                    status = t.get("last_run_status", "?")
                    status_color = C.G if status == "completed" else C.R
                    print(f"        last run: {last[:16]}  {status_color}{status}{C.E}  ({t.get('run_count', 0)} total)")

        if yaml_triggers:
            print(f"\n{C.BOLD}Declared Triggers{C.E} (in YAML workflow specs — use 'create' to activate):\n")
            for t in yaml_triggers:
                ttype = t.get("type", "?")
                wf = t.get("_workflow", "?")
                # Check if already registered
                registered = any(
                    r.get("workflow_name") == wf and r.get("trigger_name") == t.get("name")
                    for r in triggers
                )
                status = f"{C.G}active{C.E}" if registered else f"{C.Y}inactive{C.E}"
                if ttype == "schedule":
                    cron = t.get("cron", "?")
                    human = _cron_to_human(cron)
                    print(f"  {ttype}  {C.G}{wf}{C.E}  {t.get('name', '')}  {human} ({cron})  [{status}]")
                elif ttype == "webhook":
                    print(f"  {ttype}  {C.G}{wf}{C.E}  {t.get('name', '')}  [{status}]")
        print()

    elif action == "create":
        target = getattr(args, "target", None)
        if not target:
            print(f"{C.R}Usage: capa trigger create <workflow> --type schedule --cron '0 2 * * *'{C.E}")
            print(f"       capa trigger create <workflow> --type webhook --secret-env WEBHOOK_SECRET")
            sys.exit(1)

        ttype = getattr(args, "type", None)
        if not ttype:
            print(f"{C.R}--type is required (schedule or webhook){C.E}")
            sys.exit(1)

        # Verify workflow exists
        wf, wf_type = _find_workflow_for_trigger(target, base_dir)
        if not wf:
            print(f"{C.R}Workflow not found: {target}{C.E}")
            sys.exit(1)

        trigger = {
            "trigger_id": _generate_trigger_id(),
            "workflow_name": target,
            "workflow_source": wf_type,
            "type": ttype,
            "enabled": True,
            "created_at": __import__("datetime").datetime.now().isoformat(),
            "last_run_at": None,
            "last_run_status": None,
            "next_run_at": None,
            "run_count": 0,
            "consecutive_failures": 0,
        }

        if ttype == "schedule":
            cron = getattr(args, "cron", None)
            if not cron:
                print(f"{C.R}--cron is required for schedule triggers{C.E}")
                print(f"  Example: --cron '0 2 * * *'  (daily at 2:00 AM)")
                sys.exit(1)
            # Validate cron expression
            parts = cron.strip().split()
            if len(parts) != 5:
                print(f"{C.R}Invalid cron expression: {cron}{C.E}")
                print(f"  Format: minute hour day-of-month month day-of-week")
                print(f"  Example: 0 2 * * *  (daily at 2:00 AM)")
                sys.exit(1)
            trigger["cron"] = cron
            trigger["timezone"] = getattr(args, "timezone", "UTC")
            trigger["trigger_name"] = getattr(args, "trigger_name", None) or f"schedule-{target}"
            trigger["next_run_at"] = _next_cron_time(cron)
            print(f"\n{C.G}Created schedule trigger:{C.E}")
            print(f"  ID: {C.B}{trigger['trigger_id']}{C.E}")
            print(f"  Workflow: {C.G}{target}{C.E}")
            print(f"  Schedule: {_cron_to_human(cron)} ({cron})")
            if trigger["next_run_at"]:
                print(f"  Next run: {trigger['next_run_at'][:16]}")
            print(f"\n  {C.Y}Note:{C.E} Schedule runs when the backend is running,")
            print(f"  or via system cron: */1 * * * * cd {base_dir} && ./capa trigger fire {trigger['trigger_id']}")

        elif ttype == "webhook":
            import hashlib
            secret_env = getattr(args, "secret_env", None)
            trigger["trigger_name"] = getattr(args, "trigger_name", None) or f"webhook-{target}"
            if secret_env:
                secret_val = os.environ.get(secret_env, "")
                if not secret_val:
                    print(f"{C.Y}Warning: environment variable ${secret_env} is not set.{C.E}")
                    print(f"  Set it before the backend starts for webhook validation.")
                trigger["secret_env"] = secret_env
                if secret_val:
                    trigger["webhook_secret_hash"] = hashlib.sha256(secret_val.encode()).hexdigest()
            else:
                trigger["secret_env"] = None
                trigger["webhook_secret_hash"] = None
            print(f"\n{C.G}Created webhook trigger:{C.E}")
            print(f"  ID: {C.B}{trigger['trigger_id']}{C.E}")
            print(f"  Workflow: {C.G}{target}{C.E}")
            print(f"  Endpoint: POST /api/webhooks/trigger/{trigger['trigger_id']}")
            if secret_env:
                print(f"  Secret: from ${secret_env}")
                print(f"  Header: X-Hub-Signature-256: sha256=<hmac>")
            else:
                print(f"  {C.Y}No secret configured — webhook is unauthenticated{C.E}")

        triggers.append(trigger)
        state["triggers"] = triggers
        _save_trigger_state(base_dir, state)
        print()

    elif action == "show":
        target = getattr(args, "target", None)
        if not target:
            print(f"{C.R}Usage: capa trigger show <trigger_id>{C.E}")
            sys.exit(1)
        t = next((t for t in triggers if t.get("trigger_id") == target), None)
        if not t:
            print(f"{C.R}Trigger not found: {target}{C.E}")
            sys.exit(1)

        status = f"{C.G}enabled{C.E}" if t.get("enabled") else f"{C.Y}disabled{C.E}"
        print(f"\n{C.BOLD}Trigger: {t['trigger_id']}{C.E}  [{status}]")
        print(f"  Type: {t['type']}")
        print(f"  Workflow: {t['workflow_name']} ({t.get('workflow_source', '?')})")
        print(f"  Created: {t.get('created_at', '?')[:16]}")
        if t["type"] == "schedule":
            cron = t.get("cron", "?")
            print(f"  Schedule: {_cron_to_human(cron)} ({cron})")
            print(f"  Timezone: {t.get('timezone', 'UTC')}")
            if t.get("next_run_at"):
                print(f"  Next run: {t['next_run_at'][:16]}")
        elif t["type"] == "webhook":
            print(f"  Endpoint: POST /api/webhooks/trigger/{t['trigger_id']}")
            print(f"  Secret: {'configured' if t.get('webhook_secret_hash') else 'none'}")
        print(f"  Total runs: {t.get('run_count', 0)}")
        if t.get("last_run_at"):
            status_color = C.G if t.get("last_run_status") == "completed" else C.R
            print(f"  Last run: {t['last_run_at'][:16]}  {status_color}{t.get('last_run_status', '?')}{C.E}")
        if t.get("consecutive_failures", 0) > 0:
            print(f"  {C.R}Consecutive failures: {t['consecutive_failures']}{C.E}")

        # Show recent history for this trigger
        history = [h for h in state.get("run_history", []) if h.get("trigger_id") == target]
        if history:
            print(f"\n  {C.BOLD}Recent Runs:{C.E}")
            for h in history[-5:]:
                icon = f"{C.G}✓{C.E}" if h.get("status") == "completed" else f"{C.R}✗{C.E}"
                elapsed = ""
                if h.get("started_at") and h.get("completed_at"):
                    try:
                        from datetime import datetime as _dt
                        s = _dt.fromisoformat(h["started_at"].replace("Z", "+00:00"))
                        e = _dt.fromisoformat(h["completed_at"].replace("Z", "+00:00"))
                        elapsed = f" ({(e - s).total_seconds():.0f}s)"
                    except (ValueError, TypeError):
                        pass
                print(f"    {icon} {h.get('started_at', '?')[:16]}  {h.get('status', '?')}{elapsed}  {h.get('steps_completed', '?')}/{h.get('steps_total', '?')} steps")
        print()

    elif action == "enable":
        target = getattr(args, "target", None)
        if not target:
            print(f"{C.R}Usage: capa trigger enable <trigger_id>{C.E}")
            sys.exit(1)
        t = next((t for t in triggers if t.get("trigger_id") == target), None)
        if not t:
            print(f"{C.R}Trigger not found: {target}{C.E}")
            sys.exit(1)
        t["enabled"] = True
        t["consecutive_failures"] = 0
        if t["type"] == "schedule":
            t["next_run_at"] = _next_cron_time(t.get("cron", ""))
        _save_trigger_state(base_dir, state)
        print(f"{C.G}Trigger {target} enabled.{C.E}")

    elif action == "disable":
        target = getattr(args, "target", None)
        if not target:
            print(f"{C.R}Usage: capa trigger disable <trigger_id>{C.E}")
            sys.exit(1)
        t = next((t for t in triggers if t.get("trigger_id") == target), None)
        if not t:
            print(f"{C.R}Trigger not found: {target}{C.E}")
            sys.exit(1)
        t["enabled"] = False
        _save_trigger_state(base_dir, state)
        print(f"{C.Y}Trigger {target} disabled.{C.E}")

    elif action == "delete":
        target = getattr(args, "target", None)
        if not target:
            print(f"{C.R}Usage: capa trigger delete <trigger_id>{C.E}")
            sys.exit(1)
        t = next((t for t in triggers if t.get("trigger_id") == target), None)
        if not t:
            print(f"{C.R}Trigger not found: {target}{C.E}")
            sys.exit(1)
        state["triggers"] = [x for x in triggers if x.get("trigger_id") != target]
        _save_trigger_state(base_dir, state)
        print(f"{C.G}Trigger {target} deleted.{C.E}")

    elif action == "fire":
        target = getattr(args, "target", None)
        if not target:
            print(f"{C.R}Usage: capa trigger fire <trigger_id>{C.E}")
            sys.exit(1)
        t = next((t for t in triggers if t.get("trigger_id") == target), None)
        if not t:
            print(f"{C.R}Trigger not found: {target}{C.E}")
            sys.exit(1)
        if not t.get("enabled", True):
            print(f"{C.Y}Trigger {target} is disabled. Enable it first or use --force.{C.E}")
            if not getattr(args, "force", False):
                sys.exit(1)

        from datetime import datetime as _dt
        wf_name = t["workflow_name"]
        print(f"{C.BOLD}Firing trigger {target} → workflow: {wf_name}{C.E}")

        vars_override = t.get("vars_override", {})
        run_id = "trun-" + __import__("hashlib").sha256(os.urandom(16)).hexdigest()[:8]
        started_at = _dt.now().isoformat()

        success, results, elapsed = _run_workflow_by_name(
            wf_name, base_dir, registry, vars_override=vars_override, verbose=args.verbose
        )

        completed_at = _dt.now().isoformat()
        status = "completed" if success else "failed"

        # Update trigger state
        t["last_run_at"] = started_at
        t["last_run_status"] = status
        t["run_count"] = t.get("run_count", 0) + 1
        if success:
            t["consecutive_failures"] = 0
        else:
            t["consecutive_failures"] = t.get("consecutive_failures", 0) + 1
            _auto_disable_threshold = 5  # matches trigger_service.AUTO_DISABLE_THRESHOLD
            if t["consecutive_failures"] >= _auto_disable_threshold:
                t["enabled"] = False
                print(f"\n{C.R}Auto-disabled trigger after {t['consecutive_failures']} consecutive failures.{C.E}")

        if t["type"] == "schedule":
            t["next_run_at"] = _next_cron_time(t.get("cron", ""))

        # Record run history
        state.setdefault("run_history", []).append({
            "trigger_id": target,
            "run_id": run_id,
            "workflow_name": wf_name,
            "started_at": started_at,
            "completed_at": completed_at,
            "status": status,
            "steps_completed": sum(1 for r in results if r.get("status") == "completed"),
            "steps_total": len(results),
            "triggered_by": t["type"],
            "elapsed_seconds": round(elapsed, 1),
        })
        _save_trigger_state(base_dir, state)

    elif action == "history":
        limit = getattr(args, "limit", 20) or 20
        target = getattr(args, "target", None)
        history = state.get("run_history", [])
        if target:
            history = [h for h in history if h.get("trigger_id") == target]

        if not history:
            print(f"{C.Y}No trigger run history.{C.E}")
            return

        print(f"\n{C.BOLD}Trigger Run History{C.E} (last {min(limit, len(history))}):\n")
        for h in history[-limit:]:
            icon = f"{C.G}✓{C.E}" if h.get("status") == "completed" else f"{C.R}✗{C.E}"
            elapsed = f" ({h.get('elapsed_seconds', '?')}s)" if h.get("elapsed_seconds") else ""
            print(f"  {icon} {h.get('started_at', '?')[:16]}  {h.get('workflow_name', '?')}")
            print(f"    {h.get('triggered_by', '?')} → {h.get('status', '?')}{elapsed}  {h.get('steps_completed', '?')}/{h.get('steps_total', '?')} steps")
        print()

    else:
        print(f"{C.R}Unknown trigger action: {action}{C.E}")
        print(f"Usage: capa trigger [list|create|show|enable|disable|delete|fire|history]")
        sys.exit(1)


# ============================================================================

def main():
    base_dir = Path(os.path.dirname(os.path.abspath(__file__)))
    registry = FeatureRegistry(base_dir)

    parser = argparse.ArgumentParser(
        prog="capa",
        description="CAPA CLI - Declarative cluster lifecycle management",
    )
    parser.add_argument("--verbose", "-v", action="store_true", help="Verbose output")
    parser.add_argument("--dry-run", action="store_true", help="Show plan without executing")

    subparsers = parser.add_subparsers(dest="command", help="Command")

    # Shared args for most commands
    def add_common_args(p):
        p.add_argument("-f", "--file", help="ClusterAutomationSpec YAML file")
        p.add_argument("--profile", "-p", help="Profile name from specs/")
        p.add_argument("-e", "--extra-vars", action="append", metavar="KEY=VAL", help="Override variables")
        p.add_argument("--cluster", "-c", help="Cluster name")
        p.add_argument("--namespace", "-n", help="Namespace", default="ns-rosa-hcp")
        p.add_argument("--version", help="OpenShift version")

    # create
    p_create = subparsers.add_parser("create", help="Create a new cluster")
    add_common_args(p_create)
    p_create.add_argument("--name-prefix", help="Cluster name prefix")

    # upgrade
    p_upgrade = subparsers.add_parser("upgrade", help="Upgrade cluster (CP + MP)")
    add_common_args(p_upgrade)

    # apply
    p_apply = subparsers.add_parser("apply", help="Apply Day2 actions from spec")
    add_common_args(p_apply)

    # delete
    p_delete = subparsers.add_parser("delete", help="Delete a cluster")
    add_common_args(p_delete)
    p_delete.add_argument("--yes", "-y", action="store_true", help="Skip confirmation")

    # plan
    p_plan = subparsers.add_parser("plan", help="Show execution plan (dry run)")
    add_common_args(p_plan)

    # status
    p_status = subparsers.add_parser("status", help="Show cluster status")
    p_status.add_argument("--cluster", "-c", required=True, help="Cluster name")
    p_status.add_argument("--namespace", "-n", default="ns-rosa-hcp")

    # specs
    subparsers.add_parser("specs", help="List available profiles")

    # features
    subparsers.add_parser("features", help="List all features from registry")

    # set
    p_set = subparsers.add_parser("set", help="Set a single feature on a running cluster")
    p_set.add_argument("feature", help="Feature ID (e.g., channel_group)")
    p_set.add_argument("value", help="Target value (e.g., fast)")
    p_set.add_argument("--cluster", "-c", required=True, help="Cluster name")
    p_set.add_argument("--namespace", "-n", default="ns-rosa-hcp", help="Namespace")
    p_set.add_argument("--dry-run", action="store_true", dest="set_dry_run", help="Show plan without executing")

    # validate
    p_validate = subparsers.add_parser("validate", help="Validate a spec file against the registry")
    p_validate.add_argument("file", help="Path to ClusterAutomationSpec YAML file")

    # test
    p_test = subparsers.add_parser("test", help="Run test suites (passthrough to run-test-suite.py)")
    p_test.add_argument("suite_id", nargs="?", help="Test suite ID (e.g., 20-rosa-hcp-provision)")
    p_test.add_argument("--all", action="store_true", help="Run all test suites")
    p_test.add_argument("--list", action="store_true", help="List available test suites")
    p_test.add_argument("--tag", type=str, help="Filter test suites by tag")
    p_test.add_argument("--format", choices=["json", "html", "junit", "all"], help="Output format for results")
    p_test.add_argument("--no-save", action="store_true", help="Don't save results to file")
    p_test.add_argument("-e", "--extra-vars", action="append", metavar="KEY=VAL", help="Extra variables (can repeat)")
    p_test.add_argument("--ai-agent", action="store_true", help="Enable AI agent framework")
    p_test.add_argument("--ai-agent-dry-run", action="store_true", help="AI agents detect but don't fix")
    p_test.add_argument("--dry-run", action="store_true", dest="test_dry_run", help="Run in dry-run mode (no changes)")
    p_test.add_argument("-V", "--test-verbosity", action="count", default=0, help="Test verbosity (-V, -VV, -VVV)")

    # version
    subparsers.add_parser("version", help="Show CLI, registry, and agent versions")

    # list-clusters
    p_lc = subparsers.add_parser("list-clusters", help="List all managed ROSA HCP clusters")
    p_lc.add_argument("--namespace", "-n", default=None, help="Namespace (default: all)")

    # logs
    p_logs = subparsers.add_parser("logs", help="Tail sidecar or job logs for a cluster")
    p_logs.add_argument("--cluster", "-c", required=True, help="Cluster name")
    p_logs.add_argument("--lines", "-l", type=int, default=50, help="Number of lines (default: 50)")
    p_logs.add_argument("--follow", "-f", action="store_true", help="Follow log output (tail -f)")

    # history
    p_hist = subparsers.add_parser("history", help="Show operation history")
    p_hist.add_argument("--cluster", "-c", help="Filter by cluster name")
    p_hist.add_argument("--limit", type=int, default=20, help="Number of entries (default: 20)")

    # watch
    p_watch = subparsers.add_parser("watch", help="Poll cluster status until ready")
    p_watch.add_argument("--cluster", "-c", required=True, help="Cluster name")
    p_watch.add_argument("--namespace", "-n", default="ns-rosa-hcp", help="Namespace")
    p_watch.add_argument("--interval", "-i", type=int, default=30, help="Poll interval seconds (default: 30)")
    p_watch.add_argument("--timeout", "-t", type=int, default=7200, help="Timeout seconds (default: 7200)")

    # completion
    p_comp = subparsers.add_parser("completion", help="Generate shell completion script")
    p_comp.add_argument("shell", choices=["bash", "zsh"], help="Shell type")

    # generate-specs
    p_gen = subparsers.add_parser("generate-specs", help="Auto-generate feature specs from registry")
    p_gen.add_argument("--force", action="store_true", help="Overwrite existing spec files")

    # workflow
    p_wf = subparsers.add_parser("workflow", help="List, show, run, or export workflows")
    p_wf.add_argument("workflow_action", nargs="?", default="list",
                       choices=["list", "show", "run", "export"],
                       help="Action: list, show, run, or export")
    p_wf.add_argument("name", nargs="?", help="Workflow name or ID")
    p_wf.add_argument("-e", "--extra-vars", action="append", metavar="KEY=VAL",
                       help="Override variables (for run)")
    p_wf.add_argument("-o", "--output", help="Output file path (for export)")

    # trigger
    p_trig = subparsers.add_parser("trigger", help="Manage workflow triggers (schedule, webhook)")
    p_trig.add_argument("trigger_action", nargs="?", default="list",
                         choices=["list", "show", "create", "delete", "enable", "disable", "fire", "history"],
                         help="Action: list, show, create, delete, enable, disable, fire, history")
    p_trig.add_argument("target", nargs="?", help="Trigger ID or workflow name (for create)")
    p_trig.add_argument("--type", choices=["schedule", "webhook"], help="Trigger type (for create)")
    p_trig.add_argument("--cron", help="Cron expression (for schedule triggers)")
    p_trig.add_argument("--timezone", default="UTC", help="Timezone for schedule (default: UTC)")
    p_trig.add_argument("--secret-env", help="Env var name holding webhook secret")
    p_trig.add_argument("--trigger-name", help="Optional name for the trigger")
    p_trig.add_argument("--limit", type=int, default=20, help="History entries to show (default: 20)")
    p_trig.add_argument("--force", action="store_true", help="Force fire even if disabled")

    args = parser.parse_args()

    if not args.command:
        parser.print_help()
        sys.exit(1)

    commands = {
        "create": cmd_create,
        "upgrade": cmd_upgrade,
        "apply": cmd_apply,
        "delete": cmd_delete,
        "plan": cmd_plan,
        "status": cmd_status,
        "specs": cmd_specs,
        "features": cmd_features,
        "set": cmd_set,
        "validate": cmd_validate,
        "test": cmd_test,
        "version": cmd_version,
        "list-clusters": cmd_list_clusters,
        "logs": cmd_logs,
        "history": cmd_history,
        "watch": cmd_watch,
        "completion": cmd_completion,
        "generate-specs": cmd_generate_specs,
        "workflow": cmd_workflow,
        "trigger": cmd_trigger,
    }

    cmd_fn = commands.get(args.command)
    cmd_fn(args, base_dir, registry)


if __name__ == "__main__":
    main()
