def cmd_list_clusters(args, base_dir, registry):
    """List all managed ROSA HCP clusters across namespaces."""

    namespace_flag = ["-n", args.namespace] if args.namespace else ["-A"]

    try:
        result = subprocess.run(
            ["oc", "get", "rosacontrolplane"] + namespace_flag +
            ["-o", "jsonpath={range .items[*]}{.metadata.name}|{.metadata.namespace}|"
             "{.status.version}|{.status.ready}|{.spec.version}{\"\\n\"}{end}"],
            capture_output=True, text=True, timeout=15
        )
    except FileNotFoundError:
        print(f"{C.R}oc not found — is OpenShift CLI installed?{C.E}")
        sys.exit(1)

    if result.returncode != 0:
        err = result.stderr.strip()
        if "NotFound" in err or "the server doesn't have a resource type" in err:
            print(f"{C.Y}No ROSAControlPlane CRD found — CAPA may not be installed.{C.E}")
        else:
            print(f"{C.R}Error: {err}{C.E}")
        sys.exit(1)

    lines = [l.strip() for l in result.stdout.strip().split("\n") if l.strip()]
    if not lines:
        ns_label = f"namespace {args.namespace}" if args.namespace else "all namespaces"
        print(f"{C.Y}No clusters found in {ns_label}.{C.E}")
        return

    print(f"\n{C.BOLD}{'CLUSTER':<30s} {'NAMESPACE':<20s} {'VERSION':<12s} {'READY':<8s} {'UPGRADING'}{C.E}")
    print(f"{'-' * 90}")

    for line in lines:
        parts = line.split("|")
        if len(parts) < 5:
            continue
        name, ns, status_ver, ready, spec_ver = parts[0], parts[1], parts[2], parts[3], parts[4]
        upgrading = spec_ver != status_ver and status_ver and spec_ver
        ready_color = C.G if ready == "true" else C.R
        upgrade_str = f"{C.Y}{status_ver} -> {spec_ver}{C.E}" if upgrading else ""
        print(f"  {name:<28s} {ns:<20s} {status_ver:<12s} "
              f"{ready_color}{ready:<8s}{C.E} {upgrade_str}")
    print()


def cmd_logs(args, base_dir, registry):
    """Tail the sidecar log or recent job logs for a cluster."""
    cluster = args.cluster
    lines = args.lines

    # Try sidecar log first (active deletion operations)
    sidecar_path = Path(f"/tmp/deletion-agent-{cluster}.log")
    if sidecar_path.exists():
        print(f"{C.BOLD}Sidecar log: {sidecar_path}{C.E}\n")
        if args.follow:
            # Follow mode — tail -f equivalent
            print(f"{C.CYAN}Following log (Ctrl+C to stop)...{C.E}\n")
            try:
                subprocess.run(["tail", "-f", str(sidecar_path)])
            except KeyboardInterrupt:
                print(f"\n{C.Y}Stopped.{C.E}")
            return
        else:
            try:
                with open(sidecar_path) as f:
                    all_lines = f.readlines()
                for line in all_lines[-lines:]:
                    print(line, end="")
            except IOError as e:
                print(f"{C.R}Error reading sidecar log: {e}{C.E}")
            return

    # Fall back to cluster action history
    history_path = base_dir / "vars" / "cluster_action_history.json"
    if history_path.exists():
        try:
            with open(history_path) as f:
                history = json.load(f)
            cluster_entries = [e for e in history if e.get("cluster_name") == cluster]
            if cluster_entries:
                print(f"{C.BOLD}Recent operations for {cluster}:{C.E}\n")
                for entry in cluster_entries[-lines:]:
                    ts = entry.get("timestamp", "?")[:19]
                    status = entry.get("status", "?")
                    feature = entry.get("feature_id", "?")
                    msg = entry.get("message", "")
                    status_color = C.G if status == "completed" else C.R if status == "failed" else C.Y
                    print(f"  {ts}  {status_color}{status:<12s}{C.E}  {feature:<30s}  {msg}")
                print()
                return
        except (json.JSONDecodeError, IOError):
            pass

    # Check test-results for recent logs
    results_dir = base_dir / "test-results"
    if results_dir.exists():
        latest_files = sorted(results_dir.glob("latest*.json"))
        if latest_files:
            print(f"{C.Y}No active logs for '{cluster}'. Latest test results:{C.E}")
            for f in latest_files:
                print(f"  {f}")
            print()
            return

    print(f"{C.Y}No logs found for cluster '{cluster}'.{C.E}")
    print(f"  Sidecar log would be at: /tmp/deletion-agent-{cluster}.log")
    print(f"  History file: vars/cluster_action_history.json")
    print()


