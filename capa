# ============================================================================
# Terminal colors
# ============================================================================
class C:
    H = '\033[95m'; B = '\033[94m'; G = '\033[92m'; Y = '\033[93m'
    R = '\033[91m'; BOLD = '\033[1m'; E = '\033[0m'; CYAN = '\033[96m'


# ============================================================================
# Execution Engine (CLI-specific: adds terminal output, subprocess execution)
# ============================================================================
class ExecutionEngine:
    """Wraps shared plan resolution with CLI-specific execution (subprocess, terminal output)."""

    def __init__(self, registry: FeatureRegistry, base_dir: Path,
                 dry_run: bool = False, verbose: bool = False):
        self.registry = registry
        self.base_dir = base_dir
        self.dry_run = dry_run
        self.verbose = verbose

    def plan(self, spec: ClusterAutomationSpec) -> List[Dict]:
        """Generate an ordered execution plan from a spec (delegates to capa_core)."""
        return resolve_spec_to_plan(self.registry, spec)

    def execute(self, plan: List[Dict]) -> List[Dict]:
        """Execute a plan, returning results for each step."""
        results = []
        print(f"\n{C.BOLD}{C.CYAN}{'=' * 60}{C.E}")
        print(f"{C.BOLD}  Execution Plan: {len(plan)} step(s){C.E}")
        print(f"{C.BOLD}{C.CYAN}{'=' * 60}{C.E}\n")

        for step in plan:
            self._print_step(step)

        if self.dry_run:
            print(f"\n{C.Y}DRY RUN — no changes made.{C.E}\n")
            return [{"step": s["step"], "name": s["name"], "status": "dry_run"} for s in plan]

        print(f"\n{C.BOLD}Executing...{C.E}\n")

        for step in plan:
            result = self._execute_step(step)
            results.append(result)

            if result["status"] == "failed":
                print(f"\n{C.R}Step {step['step']} failed: {result.get('error', 'unknown')}{C.E}")
                print(f"{C.R}Stopping execution.{C.E}\n")
                # Mark remaining steps as skipped
                for remaining in plan[step["step"]:]:
                    results.append({
                        "step": remaining["step"],
                        "name": remaining["name"],
                        "status": "skipped",
                    })
                break

        self._print_summary(results)
        return results

    def _execute_step(self, step: Dict) -> Dict:
        """Execute a single step."""
        step_type = step["type"]
        print(f"{C.B}[Step {step['step']}]{C.E} {step['name']}...")

        if step_type == "playbook":
            return self._run_playbook(step)
        elif step_type == "patch":
            return self._run_patch(step)
        elif step_type == "test_suite":
            return self._run_test_suite(step)
        else:
            return {"step": step["step"], "name": step["name"],
                    "status": "failed", "error": f"Unknown step type: {step_type}"}

    def _run_playbook(self, step: Dict) -> Dict:
        """Run an Ansible playbook."""
        playbook_path = self.base_dir / step["playbook"]
        if not playbook_path.exists():
            return {"step": step["step"], "name": step["name"],
                    "status": "failed", "error": f"Playbook not found: {step['playbook']}"}

        cmd = ["ansible-playbook", str(playbook_path)]
        for key, value in step.get("extra_vars", {}).items():
            if isinstance(value, (dict, list)):
                cmd.extend(["-e", f"{key}={json.dumps(value)}"])
            elif isinstance(value, bool):
                cmd.extend(["-e", f"{key}={'true' if value else 'false'}"])
            else:
                cmd.extend(["-e", f"{key}={value}"])

        if self.verbose:
            cmd.append("-vvv")

        start = time.time()
        print(f"  {C.CYAN}$ {' '.join(cmd[:6])}...{C.E}")

        try:
            result = subprocess.run(
                cmd, cwd=str(self.base_dir),
                capture_output=not self.verbose,
                text=True, timeout=step.get("wait_timeout", 7200)
            )
            elapsed = time.time() - start

            if result.returncode == 0:
                print(f"  {C.G}Done ({elapsed:.0f}s){C.E}")
                return {"step": step["step"], "name": step["name"],
                        "status": "completed", "elapsed": elapsed}
            else:
                error = (result.stderr or result.stdout or "")[-500:]
                print(f"  {C.R}Failed ({elapsed:.0f}s){C.E}")
                return {"step": step["step"], "name": step["name"],
                        "status": "failed", "elapsed": elapsed, "error": error}

        except subprocess.TimeoutExpired:
            elapsed = time.time() - start
            print(f"  {C.R}Timeout ({elapsed:.0f}s){C.E}")
            return {"step": step["step"], "name": step["name"],
                    "status": "failed", "elapsed": elapsed, "error": "Timeout"}

    def _run_patch(self, step: Dict) -> Dict:
        """Execute an oc patch command."""
        resource = step["resource"].lower()
        field = step["k8s_field"]
        value = step["value"]
        cluster = step["cluster"]
        namespace = step["namespace"]

        patch_obj = build_json_merge_patch(field, value)
        patch_json = json.dumps(patch_obj)
        cmd = ["oc", "patch", resource, cluster, "-n", namespace,
               "--type=merge", "-p", patch_json]

        print(f"  {C.CYAN}$ oc patch {resource} {cluster} ...{C.E}")

        try:
            result = subprocess.run(cmd, capture_output=True, text=True, timeout=30)
            if result.returncode == 0:
                print(f"  {C.G}Patched: {field} = {value}{C.E}")
                return {"step": step["step"], "name": step["name"],
                        "status": "completed"}
            else:
                error = result.stderr.strip()
                print(f"  {C.R}Failed: {error}{C.E}")
                return {"step": step["step"], "name": step["name"],
                        "status": "failed", "error": error}
        except Exception as e:
            return {"step": step["step"], "name": step["name"],
                    "status": "failed", "error": str(e)}

    def _run_test_suite(self, step: Dict) -> Dict:
        """Run a test suite via run-test-suite.py."""
        suite_id = step["suite_id"]
        cmd = [sys.executable, str(self.base_dir / "run-test-suite.py")]

        # Find matching test suite JSON by name or use suite_id directly
        test_suites_dir = self.base_dir / "test-suites"
        suite_files = sorted(test_suites_dir.glob("*.json"))
        matched = None
        for sf in suite_files:
            try:
                with open(sf) as f:
                    data = json.load(f)
                    if data.get("name", "").lower().replace(" ", "-") == suite_id:
                        matched = sf
                        break
            except (json.JSONDecodeError, IOError):
                continue

        cmd.append(matched.stem if matched else suite_id)

        # Forward cluster/namespace as extra vars
        if step.get("cluster"):
            cmd.extend(["-e", f"cluster_name={step['cluster']}"])
        if step.get("namespace"):
            cmd.extend(["-e", f"capi_namespace={step['namespace']}"])

        # Forward extra vars from step
        for key, value in step.get("extra_vars", {}).items():
            cmd.extend(["-e", f"{key}={value}"])

        # Forward verbosity
        if self.verbose:
            cmd.append("-vvv")

        # Forward format if specified
        if step.get("format"):
            cmd.extend(["--format", step["format"]])

        # Forward ai-agent flag
        if step.get("ai_agent"):
            cmd.append("--ai-agent")

        print(f"  {C.CYAN}$ {' '.join(cmd)}{C.E}")

        try:
            result = subprocess.run(cmd, cwd=str(self.base_dir), text=True, timeout=3600)
            if result.returncode == 0:
                print(f"  {C.G}Suite passed{C.E}")
                return {"step": step["step"], "name": step["name"],
                        "status": "completed"}
            else:
                print(f"  {C.R}Suite failed{C.E}")
                return {"step": step["step"], "name": step["name"],
                        "status": "failed", "error": "Test suite failed"}
        except Exception as e:
            return {"step": step["step"], "name": step["name"],
                    "status": "failed", "error": str(e)}

    def _print_step(self, step: Dict):
        """Pretty-print a plan step."""
        icon = {"playbook": "📦", "patch": "🔧", "test_suite": "🧪"}.get(step["type"], "▶")
        dep = f" (after {step['depends_on']})" if step.get("depends_on") else ""
        cond = f"  {C.Y}if: {step['if']}{C.E}" if step.get("if") else ""
        print(f"  {icon} Step {step['step']}: {step['name']}{dep}{cond}")
        if step["type"] == "playbook" and self.verbose:
            for k, v in step.get("extra_vars", {}).items():
                val = str(v)[:50]
                print(f"      {k}: {val}")

    def _print_summary(self, results: List[Dict]):
        """Print execution summary."""
        total = len(results)
        passed = sum(1 for r in results if r["status"] == "completed")
        failed = sum(1 for r in results if r["status"] == "failed")
        skipped = sum(1 for r in results if r["status"] == "skipped")

        print(f"\n{C.BOLD}{C.CYAN}{'=' * 60}{C.E}")
        print(f"{C.BOLD}  Results: {passed}/{total} passed", end="")
        if failed:
            print(f", {C.R}{failed} failed{C.E}", end="")
        if skipped:
            print(f", {C.Y}{skipped} skipped{C.E}", end="")
        print(f"{C.E}")
        print(f"{C.BOLD}{C.CYAN}{'=' * 60}{C.E}\n")

        for r in results:
            icon = {"completed": C.G + "✓", "failed": C.R + "✗",
                    "skipped": C.Y + "○", "dry_run": C.B + "◇"}.get(r["status"], "?")
            elapsed = f" ({r['elapsed']:.0f}s)" if "elapsed" in r else ""
            print(f"  {icon} Step {r['step']}: {r['name']}{elapsed}{C.E}")

        print()


