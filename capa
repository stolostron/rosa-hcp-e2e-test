def load_spec(args, base_dir: Path) -> ClusterAutomationSpec:
    """Load a ClusterAutomationSpec from file, profile, or inline args."""
    overrides = {}
    if hasattr(args, "extra_vars") and args.extra_vars:
        for ev in args.extra_vars:
            if "=" in ev:
                k, v = ev.split("=", 1)
                # Auto-parse booleans and numbers
                if v.lower() in ("true", "false"):
                    v = v.lower() == "true"
                elif v.isdigit() or (v.startswith("-") and v[1:].isdigit()):
                    v = int(v)
                overrides[k] = v

    # Override from explicit CLI args
    if hasattr(args, "cluster") and args.cluster:
        overrides["cluster"] = args.cluster
    if hasattr(args, "version") and args.version:
        overrides["version"] = args.version
    if hasattr(args, "namespace") and args.namespace:
        overrides["namespace"] = args.namespace
    if hasattr(args, "name_prefix") and args.name_prefix:
        overrides["name_prefix"] = args.name_prefix

    if hasattr(args, "file") and args.file:
        with open(args.file) as f:
            data = yaml.safe_load(f)
        return ClusterAutomationSpec(data, overrides, base_dir=base_dir)

    if hasattr(args, "profile") and args.profile:
        # Search all subdirectories under specs/
        profile_path = None
        for candidate in (base_dir / "specs").rglob(f"{args.profile}.yml"):
            profile_path = candidate
            break
        if not profile_path or not profile_path.exists():
            print(f"{C.R}Profile not found: {args.profile}{C.E}")
            all_specs = [p.stem for p in (base_dir / "specs").rglob("*.yml")]
            print(f"Available: {', '.join(sorted(all_specs))}")
            sys.exit(1)
        with open(profile_path) as f:
            data = yaml.safe_load(f)
        return ClusterAutomationSpec(data, overrides, base_dir=base_dir)

    # Build inline spec from command args
    action = args.command if hasattr(args, "command") else "status"
    data = {
        "apiVersion": "capa-automation/v1",
        "kind": "ClusterAutomationSpec",
        "metadata": {"name": f"cli-{action}"},
        "spec": {"action": action},
    }
    return ClusterAutomationSpec(data, overrides, base_dir=base_dir)


def cmd_create(args, base_dir, registry):
    spec = load_spec(args, base_dir)
    spec.spec["action"] = "create"
    engine = ExecutionEngine(registry, base_dir, dry_run=args.dry_run, verbose=args.verbose)
    plan = engine.plan(spec)
    engine.execute(plan)


