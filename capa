def cmd_delete(args, base_dir, registry):
    spec = load_spec(args, base_dir)
    spec.spec["action"] = "delete"
    if not args.yes:
        cluster = spec.cluster or args.cluster
        confirm = input(f"{C.R}Delete cluster '{cluster}'? This cannot be undone. [y/N]: {C.E}")
        if confirm.lower() != "y":
            print("Cancelled.")
            return
    engine = ExecutionEngine(registry, base_dir, dry_run=args.dry_run, verbose=args.verbose)
    plan = engine.plan(spec)
    engine.execute(plan)


def cmd_plan(args, base_dir, registry):
    """Show execution plan without running anything."""
    args.dry_run = True
    spec = load_spec(args, base_dir)
    engine = ExecutionEngine(registry, base_dir, dry_run=True, verbose=args.verbose)
    plan = engine.plan(spec)
    engine.execute(plan)


def cmd_status(args, base_dir, registry):
    """Show cluster status."""

    cluster = args.cluster
    namespace = args.namespace or "ns-rosa-hcp"
    if not cluster:
        print(f"{C.R}--cluster required{C.E}")
        sys.exit(1)

    print(f"\n{C.BOLD}Cluster: {cluster}{C.E}")
    print(f"Namespace: {namespace}\n")

    # ROSAControlPlane
    try:
        result = subprocess.run(
            ["oc", "get", "rosacontrolplane", cluster, "-n", namespace,
             "-o", "jsonpath={.spec.version}|{.status.version}|{.status.ready}|{.status.availableUpgrades}"],
            capture_output=True, text=True, timeout=10
        )
        if result.returncode == 0:
            parts = result.stdout.split("|")
            spec_ver = parts[0] if len(parts) > 0 else "?"
            status_ver = parts[1] if len(parts) > 1 else "?"
            ready = parts[2] if len(parts) > 2 else "?"
            upgrades = parts[3] if len(parts) > 3 else "[]"
            upgrading = spec_ver != status_ver and status_ver

            print(f"  Control Plane:")
            print(f"    Version: {status_ver}", end="")
            if upgrading:
                print(f" {C.Y}-> {spec_ver} (upgrading){C.E}")
            else:
                print()
            print(f"    Ready: {C.G if ready == 'true' else C.R}{ready}{C.E}")
            if upgrades and upgrades != "[]":
                print(f"    Available: {upgrades}")
    except Exception as e:
        print(f"  {C.R}Error reading ROSAControlPlane: {e}{C.E}")

    # ROSAMachinePool
    try:
        result = subprocess.run(
            ["oc", "get", "rosamachinepool", cluster, "-n", namespace,
             "-o", "jsonpath={.spec.version}|{.status.ready}|{.status.availableUpgrades}|{.status.replicas}"],
            capture_output=True, text=True, timeout=10
        )
        if result.returncode == 0:
            parts = result.stdout.split("|")
            mp_ver = parts[0] if len(parts) > 0 else "?"
            mp_ready = parts[1] if len(parts) > 1 else "?"
            mp_upgrades = parts[2] if len(parts) > 2 else "[]"
            mp_replicas = parts[3] if len(parts) > 3 else "?"

            print(f"\n  Machine Pool:")
            print(f"    Version: {mp_ver}")
            print(f"    Ready: {C.G if mp_ready == 'true' else C.R}{mp_ready}{C.E}")
            print(f"    Replicas: {mp_replicas}")
            if mp_upgrades and mp_upgrades != "[]":
                print(f"    Available: {mp_upgrades}")
    except Exception:
        pass

    # ROSANetwork
    try:
        result = subprocess.run(
            ["oc", "get", "rosanetwork", cluster, "-n", namespace,
             "-o", "jsonpath={.status.ready}|{.status.stackStatus}|{.status.vpcID}"],
            capture_output=True, text=True, timeout=10
        )
        if result.returncode == 0 and result.stdout.strip():
            parts = result.stdout.split("|")
            net_ready = parts[0] if len(parts) > 0 else "?"
            stack_status = parts[1] if len(parts) > 1 else "?"
            vpc_id = parts[2] if len(parts) > 2 else "?"

            print(f"\n  Network:")
            print(f"    Ready: {C.G if net_ready == 'true' else C.R}{net_ready}{C.E}")
            if stack_status:
                stack_color = C.G if "COMPLETE" in stack_status and "DELETE" not in stack_status else C.R if "FAILED" in stack_status else C.Y
                print(f"    CloudFormation: {stack_color}{stack_status}{C.E}")
            if vpc_id:
                print(f"    VPC: {vpc_id}")
    except Exception:
        pass

    # ROSARoleConfig
    try:
        result = subprocess.run(
            ["oc", "get", "rosaroleconfig", cluster, "-n", namespace,
             "-o", "jsonpath={.status.ready}"],
            capture_output=True, text=True, timeout=10
        )
        if result.returncode == 0 and result.stdout.strip():
            role_ready = result.stdout.strip()
            print(f"\n  Role Config:")
            print(f"    Ready: {C.G if role_ready == 'true' else C.R}{role_ready}{C.E}")
    except Exception:
        pass

    print()


def cmd_specs(args, base_dir, registry):
    """List available specs by category."""
    specs_dir = base_dir / "specs"
    categories = [
        ("Profiles", specs_dir / "profiles", "Cluster creation presets"),
        ("Features", specs_dir / "features", "Individual feature actions"),
    ]
    print(f"\n{C.BOLD}Available Specs:{C.E}")
    for cat_name, cat_dir, cat_desc in categories:
        if not cat_dir.exists():
            continue
        files = sorted(cat_dir.glob("*.yml"))
        if not files:
            continue
        print(f"\n  {C.BOLD}{C.CYAN}{cat_name}{C.E} — {cat_desc}")
        for spec_file in files:
            try:
                with open(spec_file) as f:
                    data = yaml.safe_load(f)
            except (yaml.YAMLError, IOError) as e:
                print(f"    {C.BOLD}{spec_file.stem}{C.E}")
                print(f"      {C.R}(error reading: {e}){C.E}")
                continue
            name = data.get("metadata", {}).get("name", spec_file.stem)
            action = data.get("spec", {}).get("action", "?")
            features = data.get("spec", {}).get("features", {})
            actions_list = data.get("spec", {}).get("actions", [])
            detail = ""
            if features:
                detail = ", ".join(list(features.keys())[:4])
            elif actions_list:
                detail = " → ".join(a.get("feature", "") for a in actions_list)
            print(f"    {C.BOLD}{spec_file.stem}{C.E}")
            print(f"      {action} | {detail or '(no features)'}")

    # Point to unified workflow command
    wf_dir = specs_dir / "workflows"
    wf_json = base_dir / "vars" / "saved_workflows.json"
    wf_count = len(list(wf_dir.glob("*.yml"))) if wf_dir.exists() else 0
    saved_count = 0
    if wf_json.exists():
        try:
            with open(wf_json) as f:
                saved_count = len(json.load(f))
        except (json.JSONDecodeError, IOError):
            pass
    total_wf = wf_count + saved_count
    if total_wf:
        print(f"\n  {C.BOLD}{C.CYAN}Workflows{C.E} — {total_wf} workflow(s) available")
        print(f"    Run {C.CYAN}./capa workflow list{C.E} to see all workflows")
    print()


def cmd_features(args, base_dir, registry):
    """List all features from the registry."""
    print(f"\n{C.BOLD}Feature Registry:{C.E}\n")
    for suite in registry.suites:
        phase_color = C.B if suite["phase"] == "Day2" else C.CYAN
        print(f"  {C.BOLD}{suite['name']}{C.E} {phase_color}[{suite['phase']}]{C.E}")
        for feat in suite["features"]:
            mutable = f"{C.G}mutable{C.E}" if feat["mutable"] else f"{C.Y}immutable{C.E}"
            applies = ",".join(feat.get("applies_to", []))
            deps = registry.get_deps(feat["id"])
            dep_str = f" (after {', '.join(deps)})" if deps else ""
            print(f"    {feat['id']:30s} {mutable}  {applies:14s} {feat['type']:10s} {feat.get('resource', '')}{dep_str}")
    print()


def cmd_set(args, base_dir, registry):
    """Quick shorthand: set a single feature value on a running cluster.

    Examples:
        ./capa set channel_group fast --cluster moo-rosa-hcp
        ./capa set audit_logging cloudwatch -c moo-rosa-hcp
        ./capa set proxy_enabled true -c moo-rosa-hcp
    """
    feature_id = args.feature
    value = args.value
    cluster = args.cluster
    namespace = args.namespace or "ns-rosa-hcp"

    feat = registry.get_feature(feature_id)
    if not feat:
        print(f"{C.R}Unknown feature: {feature_id}{C.E}")
        # Suggest similar features
        all_ids = list(registry.all_features().keys())
        matches = [f for f in all_ids if feature_id in f or f in feature_id]
        if matches:
            print(f"Did you mean: {', '.join(matches)}")
        sys.exit(1)

    if not feat.get("mutable"):
        print(f"{C.R}Feature '{feature_id}' is immutable — cannot be changed after creation.{C.E}")
        sys.exit(1)

    applies_to = feat.get("applies_to", [])
    if "apply" not in applies_to and "upgrade" not in applies_to:
        print(f"{C.R}Feature '{feature_id}' does not support apply/upgrade (applies_to: {applies_to}).{C.E}")
        sys.exit(1)

    # Auto-parse value
    if value.lower() in ("true", "false"):
        value = value.lower() == "true"
    else:
        try:
            value = int(value)
        except (ValueError, TypeError):
            pass

    # Validate value against type
    _validate_feature_value_exit(feat, value)

    # Build inline spec
    data = {
        "apiVersion": "capa-automation/v1",
        "kind": "ClusterAutomationSpec",
        "metadata": {"name": f"set-{feature_id}"},
        "spec": {
            "action": "apply",
            "cluster": cluster,
            "namespace": namespace,
            "actions": [{"feature": feature_id, "value": value}],
        },
    }
    spec = ClusterAutomationSpec(data)
    dry_run = args.dry_run or getattr(args, "set_dry_run", False)
    engine = ExecutionEngine(registry, base_dir, dry_run=dry_run, verbose=args.verbose)
    plan = engine.plan(spec)
    engine.execute(plan)


def _validate_feature_value_exit(feat, value):
    """Validate a value against a feature's type constraints. Exits on error."""
    err = validate_feature_value(feat, value)
    if err:
        print(f"{C.R}{err}{C.E}")
        sys.exit(1)


def cmd_validate(args, base_dir, registry):
    """Validate a ClusterAutomationSpec file against the feature registry."""
    spec_path = args.file
    if not os.path.exists(spec_path):
        print(f"{C.R}File not found: {spec_path}{C.E}")
        sys.exit(1)

    with open(spec_path) as f:
        data = yaml.safe_load(f)

    errors = []
    warnings = []

    # Check required top-level fields
    if data.get("apiVersion") != "capa-automation/v1":
        errors.append(f"Invalid apiVersion: {data.get('apiVersion')} (expected capa-automation/v1)")
    if data.get("kind") != "ClusterAutomationSpec":
        errors.append(f"Invalid kind: {data.get('kind')} (expected ClusterAutomationSpec)")
    if not data.get("metadata", {}).get("name"):
        warnings.append("Missing metadata.name")

    spec = data.get("spec", {})
    action = spec.get("action", "")
    valid_actions = ["create", "apply", "upgrade", "delete", "test"]
    if action not in valid_actions:
        errors.append(f"Invalid action: '{action}' (expected one of {valid_actions})")

    # Validate features (for create specs)
    features = spec.get("features", {})
    for feat_id, value in features.items():
        feat = registry.get_feature(feat_id)
        if not feat:
            errors.append(f"Unknown feature: '{feat_id}'")
            continue
        applies_to = feat.get("applies_to", [])
        if action and action not in applies_to:
            errors.append(f"Feature '{feat_id}' does not apply to '{action}' (applies_to: {applies_to})")
        # Type validation
        _validate_feature_value_check(feat, value, errors, warnings)

    # Validate actions list (for apply/upgrade specs)
    actions_list = spec.get("actions", [])
    for i, act in enumerate(actions_list):
        feat_id = act.get("feature")
        if not feat_id:
            errors.append(f"Action [{i}]: missing 'feature' field")
            continue
        feat = registry.get_feature(feat_id)
        if not feat:
            errors.append(f"Action [{i}]: unknown feature '{feat_id}'")
            continue
        applies_to = feat.get("applies_to", [])
        if action and action not in applies_to:
            errors.append(f"Action [{i}]: feature '{feat_id}' does not apply to '{action}' (applies_to: {applies_to})")
        if not feat.get("mutable") and action in ("apply", "upgrade"):
            errors.append(f"Action [{i}]: feature '{feat_id}' is immutable — cannot be changed after creation")
        value = act.get("value")
        if value is not None:
            _validate_feature_value_check(feat, value, errors, warnings)

    # Check dependency ordering
    seen_features = set()
    for i, act in enumerate(actions_list):
        feat_id = act.get("feature", "")
        deps = registry.get_deps(feat_id)
        for dep in deps:
            if dep not in seen_features:
                dep_in_list = any(a.get("feature") == dep for a in actions_list)
                if dep_in_list:
                    warnings.append(f"Action [{i}]: '{feat_id}' depends on '{dep}' which appears later in the list")
                else:
                    warnings.append(f"Action [{i}]: '{feat_id}' depends on '{dep}' which is not in the spec")
        seen_features.add(feat_id)

    # Cluster required for certain actions
    if action in ("apply", "upgrade", "delete") and not spec.get("cluster"):
        warnings.append(f"No cluster specified — will need --cluster at runtime")

    # Print results
    print(f"\n{C.BOLD}Validating: {spec_path}{C.E}")
    print(f"  Kind: {data.get('kind', '?')}")
    print(f"  Action: {action}")
    print(f"  Features: {len(features)}, Actions: {len(actions_list)}")

    if errors:
        print(f"\n  {C.R}{C.BOLD}{len(errors)} error(s):{C.E}")
        for e in errors:
            print(f"    {C.R}✗ {e}{C.E}")

    if warnings:
        print(f"\n  {C.Y}{len(warnings)} warning(s):{C.E}")
        for w in warnings:
            print(f"    {C.Y}⚠ {w}{C.E}")

    if not errors and not warnings:
        print(f"\n  {C.G}✓ Valid spec — no issues found.{C.E}")
    elif not errors:
        print(f"\n  {C.G}✓ Valid spec (with warnings).{C.E}")
    else:
        print(f"\n  {C.R}✗ Invalid spec.{C.E}")
        sys.exit(1)

    print()


def _validate_feature_value_check(feat, value, errors, warnings):
    """Validate a value against feature type, appending to errors list."""
    err = validate_feature_value(feat, value)
    if err:
        errors.append(err)


def cmd_test(args, base_dir, registry):
    """Run test suites via run-test-suite.py with full flag passthrough.

    Examples:
        ./capa test 20-rosa-hcp-provision
        ./capa test 20-rosa-hcp-provision --ai-agent -vvv --format junit
        ./capa test --list
        ./capa test --all --tag rosa-hcp
        ./capa test 30-rosa-hcp-delete -e cluster_name=my-rosa-hcp --ai-agent
    """
    runner_path = base_dir / "run-test-suite.py"
    if not runner_path.exists():
        print(f"{C.R}run-test-suite.py not found at {runner_path}{C.E}")
        sys.exit(1)

    cmd = [sys.executable, str(runner_path)]

    # Positional suite ID
    if args.suite_id:
        cmd.append(args.suite_id)

    # Boolean flags
    if args.all:
        cmd.append("--all")
    if args.list:
        cmd.append("--list")
    if args.ai_agent:
        cmd.append("--ai-agent")
    if args.ai_agent_dry_run:
        cmd.append("--ai-agent-dry-run")
    if args.dry_run or getattr(args, "test_dry_run", False):
        cmd.append("--dry-run")
    if args.no_save:
        cmd.append("--no-save")

    # Tag filter
    if args.tag:
        cmd.extend(["--tag", args.tag])

    # Output format
    if args.format:
        cmd.extend(["--format", args.format])

    # Verbosity (map -v count to -v/-vv/-vvv/-vvvv)
    if args.test_verbosity and args.test_verbosity > 0:
        cmd.append("-" + "v" * min(args.test_verbosity, 4))

    # Extra vars passthrough
    if args.extra_vars:
        for ev in args.extra_vars:
            cmd.extend(["-e", ev])

    if args.verbose:
        print(f"{C.CYAN}$ {' '.join(cmd)}{C.E}\n")

    try:
        result = subprocess.run(cmd, cwd=str(base_dir))
        sys.exit(result.returncode)
    except KeyboardInterrupt:
        print(f"\n{C.Y}Interrupted.{C.E}")
        sys.exit(130)


