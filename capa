def cmd_watch(args, base_dir, registry):
    """Poll cluster status until ready or timeout."""

    cluster = args.cluster
    namespace = args.namespace or "ns-rosa-hcp"
    interval = args.interval
    timeout = args.timeout

    print(f"\n{C.BOLD}Watching cluster: {cluster}{C.E}", flush=True)
    print(f"  Namespace: {namespace}", flush=True)
    print(f"  Interval: {interval}s, Timeout: {timeout}s", flush=True)
    print(f"  {C.CYAN}Press Ctrl+C to stop{C.E}\n", flush=True)

    start = time.time()
    last_status = None

    try:
        while True:
            elapsed = time.time() - start
            if elapsed > timeout:
                print(f"\n{C.R}Timeout after {timeout}s — cluster not ready.{C.E}\n")
                sys.exit(1)

            # Check control plane
            try:
                result = subprocess.run(
                    ["oc", "get", "rosacontrolplane", cluster, "-n", namespace,
                     "-o", "jsonpath={.status.version}|{.status.ready}|{.spec.version}"],
                    capture_output=True, text=True, timeout=10
                )
            except FileNotFoundError:
                print(f"{C.R}oc not found{C.E}")
                sys.exit(1)

            if result.returncode != 0:
                ts = datetime.now().strftime("%H:%M:%S")
                print(f"  {ts}  {C.Y}Cluster not found yet...{C.E}")
                time.sleep(interval)
                continue

            parts = result.stdout.split("|")
            status_ver = parts[0] if len(parts) > 0 else "?"
            ready = parts[1] if len(parts) > 1 else "?"
            spec_ver = parts[2] if len(parts) > 2 else "?"
            upgrading = spec_ver != status_ver and status_ver and spec_ver

            # Check machine pool
            mp_ready = "?"
            try:
                mp_result = subprocess.run(
                    ["oc", "get", "rosamachinepool", cluster, "-n", namespace,
                     "-o", "jsonpath={.status.ready}"],
                    capture_output=True, text=True, timeout=10
                )
                if mp_result.returncode == 0:
                    mp_ready = mp_result.stdout.strip() or "?"
            except Exception:
                pass

            # Build status line
            ts = datetime.now().strftime("%H:%M:%S")
            current_status = f"cp={ready} mp={mp_ready} v={status_ver}"

            ready_color = C.G if ready == "true" else C.Y
            mp_color = C.G if mp_ready == "true" else C.Y
            upgrade_info = f" {C.Y}upgrading -> {spec_ver}{C.E}" if upgrading else ""
            changed = " *" if current_status != last_status else ""
            print(f"  {ts}  CP: {ready_color}{ready}{C.E}  "
                  f"MP: {mp_color}{mp_ready}{C.E}  "
                  f"Version: {status_ver}{upgrade_info}  "
                  f"({int(elapsed)}s){changed}", flush=True)
            last_status = current_status

            # Check if fully ready
            if ready == "true" and mp_ready == "true" and not upgrading:
                print(f"\n{C.G}{C.BOLD}Cluster {cluster} is ready! "
                      f"(v{status_ver}, {int(elapsed)}s){C.E}\n")
                return

            time.sleep(interval)

    except KeyboardInterrupt:
        print(f"\n\n{C.Y}Stopped watching after {int(time.time() - start)}s.{C.E}\n")


